# Authors: Kuruma, Letifer

# Discord
DISCORD_TOKEN=
CLIENT_ID=
COMMAND_GUILD_ID=

# Bot
NODE_ENV=development
LOG_LEVEL=info
PREFIX_SYMBOL=!
DEFAULT_MODE=bridge
OWNER_IDS=

# AI Provider Selection
# none | openai | grok | claude | openai-compatible | openrouter
AI_PROVIDER=none

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# xAI / Grok
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Any OpenAI-compatible API
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_BASE_URL=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Kuruma Discord Bot
OPENROUTER_MAX_TOKENS=2048

# Execution / Safety
EXECUTION_DELAY_MS=350
ALLOW_DESTRUCTIVE_OPERATIONS=false
MAX_CONVERSATION_TURNS=12
MAX_PENDING_PLANS=10
